<node id="Wang Xiang">
  <data key="d0">Wang Xiang</data>
  <data key="d1">person</data>
  <data key="d2">Wang Xiang is a senior executive who joined Xiaomi to strengthen supply chain management in 2016. He previously served as Vice President at Qualcomm globally.</data>
