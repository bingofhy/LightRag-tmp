<graph edgedefault="undirected"><node id="Xiaomi Company">
  <data key="d0">Xiaomi Company</data>
  <data key="d1">organization</data>
  <data key="d2">Xiaomi Company is a technology company founded in April 2010 by Lei Jun and seven co-founders, headquartered in Beijing. It evolved from a software OS developer (MIUI) to a global technology ecosystem leader, known for its smartphones, smart devices, and internet services.</data>
  <data key="d3">chunk-3d53115d4331a6108b6e778bee3c915f</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1779357459</data>
  <data key="d6"></data>
</node>
<node id="Lei Jun">
  <data key="d0">Lei Jun</data>
  <data key="d1">person</data>
  <data key="d2">Lei Jun is the founder and CEO of Xiaomi, who announced the company's entry into the smart electric vehicle industry in March 2021, describing it as his final entrepreneurial venture.&lt;SEP&gt;Lei Jun is the founder and chairman of Xiaomi Company. He led the company's founding in 2010 and personally took over smartphone R&amp;D and supply chain management in 2016. He committed that Xiaomi's hardware net profit margin would never exceed 5%.</data>
  <data key="d3">chunk-3d53115d4331a6108b6e778bee3c915f&lt;SEP&gt;chunk-fdb937e9e57716d51ecc291d0e052dfc</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1779357459</data>
  <data key="d6"></data>
</node>
